{
  "name": "@vectrill/spreadsheet",
  "version": "1.0.0",
  "description": "Vectrill Spreadsheet Integration - Excel and Google Sheets add-ins",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:api && npm run build:excel && npm run build:google-sheets",
    "build:api": "tsc --build false || echo 'No TypeScript files to compile, skipping build'",
    "build:excel": "cd excel && npm run build",
    "build:google-sheets": "cd google-sheets && npm run build",
    "dev": "npm run dev:api",
    "dev:api": "tsc --watch",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit/",
    "test:integration": "jest tests/integration/",
    "test:e2e": "jest tests/e2e/",
    "lint": "eslint src/ --ext .ts,.js",
    "lint:fix": "eslint src/ --ext .ts,.js --fix",
    "format": "prettier --write src/",
    "validate": "npm run lint && npm run test && npm run build",
    "docs": "typedoc src/ --out docs/",
    "clean": "rimraf dist/ target/",
    "prepare": "npm run build",
    "prepublishOnly": "npm run validate"
  },
  "keywords": [
    "vectrill",
    "spreadsheet",
    "excel",
    "google-sheets",
    "data-transformation",
    "analytics",
    "add-in"
  ],
  "author": "Vectrill Team <support@vectrill.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FranekJemiolo/vectrill.git",
    "directory": "spreadsheet"
  },
  "bugs": {
    "url": "https://github.com/FranekJemiolo/vectrill/issues"
  },
  "homepage": "https://github.com/FranekJemiolo/vectrill/tree/main/spreadsheet",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.25.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "axios": "^1.5.0",
    "commander": "^11.0.0",
    "winston": "^3.10.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "extends": [
      "@typescript-eslint/recommended",
      "prettier"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/explicit-function-return-type": "warn"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "files": [
    "dist/",
    "api/",
    "templates/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
